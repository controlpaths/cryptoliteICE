# For PCBs designed using KiCad: https://www.kicad.org/
# Format documentation: https://kicad.org/help/file-formats/

# Temporary files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*-cache*
*-bak
*-bak*
*~
~*
_autosave-*
\#auto_saved_files\#
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Netlist files (exported from Eeschema)
*.net

# Autorouter files (exported from Pcbnew)
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv

# Archived Backups (KiCad 6.0)
**/*-backups/*.zip

# Local git-based history (KiCad 9.0+)
.history

# Local project settings
*.kicad_prl

# ── Firmware / FPGA / host build artifacts ──────────────────────────────
# Build output trees (created by the build_*.sh scripts)
build/

# Pico SDK — provide your own checkout (submodule or PICO_SDK_PATH)
pico-sdk/

# FPGA toolchain intermediates and bitstreams
*.json
*.asc
*.bin

# RP2040 firmware images
*.uf2
*.elf
*.hex
*.dis
*.map

# Simulation output (iverilog / vvp)
*.vcd
*.out
a.out

# Python
.venv/
__pycache__/
*.pyc
